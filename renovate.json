{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranchPatterns": [
    "main"
  ],
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":pinDevDependencies"
  ],
  "pre-commit": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update _VERSION ARGs in Dockerfile via renovate comments",
      "fileMatch": [
        "(^|/|\\.)Dockerfile$",
        "(^|/)Dockerfile\\.[^/]*$"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s+ARG\\s+\\w+=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Own freshly-built ghcr images rebuild several times a day; the global 3-day minimumReleaseAge clock resets on every digest rebase, deadlocking automerge. Opt them out so digest bumps automerge immediately.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/bl4ko/**"
      ],
      "minimumReleaseAge": null
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true,
      "groupName": "github actions"
    },
    {
      "matchManagers": [
        "pre-commit"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": true
    }
  ],
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "timezone": "Europe/Ljubljana",
  "minimumReleaseAge": "3 days"
}
